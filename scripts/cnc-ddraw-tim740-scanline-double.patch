diff --git a/src/render_gdi.c b/src/render_gdi.c
index c7292ed..a82bc19 100644
--- a/src/render_gdi.c
+++ b/src/render_gdi.c
@@ -101,6 +101,59 @@ DWORD WINAPI gdi_render_main(void)
 
             int lines_copied = 0;
 
+            /* TIM-740: workaround for games (Red Alert / RA95) that write to a
+             * 640x400-style "scanline-doubled" surface in DDSCL_EXCLUSIVE +
+             * SetDisplayMode(640,400,8) mode. The VQA player decoder writes one
+             * source scanline per pair of physical rows, assuming the CRT
+             * hardware will duplicate the row beneath it. Under cnc-ddraw the
+             * buffer is rendered as-is so every other physical row stays at
+             * the zero-fill background colour ("alternate scanlines black"
+             * artefact, see TIM-740).
+             *
+             * When g_config.scanline_double is set, we walk each (2i, 2i+1)
+             * pair before render and, if row 2i+1 is all-zero, copy row 2i
+             * into it. The all-zero guard avoids corrupting overlay/text
+             * elements drawn contiguously by the game (e.g. the top border)
+             * while still doubling VQA frame content. */
+            if (g_config.scanline_double && g_ddraw.primary->bpp == 8)
+            {
+                /* For each pair (even, odd), if the odd row contains far less
+                 * pixel data than the even row above, treat it as a scanline-
+                 * doubled gap and copy the even row down. We compare row byte
+                 * sums (palette-index magnitude is a usable "energy" proxy):
+                 * if odd_sum * 10 < even_sum and even_sum exceeds a small
+                 * floor, the odd row is treated as missing.
+                 *
+                 * This preserves already-doubled regions (where odd_sum ~=
+                 * even_sum) like overlay text, while still filling the gaps
+                 * the VQA player leaves for hardware scanline replication. */
+                unsigned char* buf = (unsigned char*)g_ddraw.primary->surface;
+                unsigned width = g_ddraw.primary->width;
+                unsigned pitch = g_ddraw.primary->pitch;
+                unsigned height = g_ddraw.primary->height;
+                for (unsigned y = 0; y + 1 < height; y += 2)
+                {
+                    unsigned char* even_row = buf + (size_t)y * pitch;
+                    unsigned char* odd_row  = even_row + pitch;
+                    unsigned long even_sum = 0, odd_sum = 0;
+                    for (unsigned i = 0; i < width; i++)
+                    {
+                        even_sum += even_row[i];
+                        odd_sum  += odd_row[i];
+                    }
+                    /* Symmetric doubling: whichever row has real content
+                     * (>= 256 ~ 1 byte/pixel average across a 640-wide row of
+                     * palette idx 0-1) gets copied to its neighbour when the
+                     * neighbour holds < 10% of its sum (gap / fill). RA's VQA
+                     * player can scanline-double from either phase depending
+                     * on the frame chunk, so we handle both. */
+                    if (even_sum >= 256 && odd_sum * 10 < even_sum)
+                        memcpy(odd_row, even_row, width);
+                    else if (odd_sum >= 256 && even_sum * 10 < odd_sum)
+                        memcpy(even_row, odd_row, width);
+                }
+            }
+
             if (g_ddraw.bnet_active)
             {
                 RECT rc = { 0, 0, g_ddraw.render.width, g_ddraw.render.height };
